# ── Solana ────────────────────────────────────────────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
RPC_URL_FALLBACK=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=devnet
SOLANA_WALLET_ADDRESS=YOUR_WALLET_PUBLIC_KEY
SOLANA_WALLET_PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY

# ── OSINT / external APIs ─────────────────────────────────────────────────────
ARKHAM_API_KEY=YOUR_ARKHAM_KEY_HERE
RUGCHECK_API_URL=https://api.rugcheck.xyz/v1
BUBBLEMAP_API_URL=https://api.bubblemaps.io

# ── Telegram alerts ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Engine tuning ─────────────────────────────────────────────────────────────
ALPHA_LOG_LEVEL=INFO
ALPHA_LOG_DIR=logs
ALPHA_DB_PATH=data/alpha_engine.db
ALPHA_PID_FILE=alpha_engine.pid
